# ============================================================
# Jimmy — Environment Variables
#
# You do NOT need to create this file manually.
# Run `jimmy jet` and complete the setup wizard —
# Jimmy will generate and maintain .env automatically.
#
# This file is only here as a reference.
# ============================================================

# ── LLM Providers (at least one required) ───────────────────
OPENROUTER_KEY=sk-or-v1-...
OPENROUTER_MODEL=openrouter/free
OPENROUTER_TIER=free                  # free | paid

GOOGLE_GENERATIVE_AI_API_KEY=AIza...
GROQ_API_KEY=gsk_...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Preferred provider order (comma-separated)
PREFERRED_PROVIDERS=gemini,groq

# ── Supabase (required for Scheduler mode) ──────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Gmail OAuth (required for Email operations) ─────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
PORT=8787

# ── Web tools ───────────────────────────────────────────────
FIRECRAWL_KEY=fc-...
APIFY_API_KEY=apify_api_...

# ── Telegram bot ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_OWNER_ID=123456789

# ── Browser automation ──────────────────────────────────────
BROWSERBASE_API_KEY=bb_live_...
BROWSERBASE_PRODUCT_ID=xxxxxxxx-...
